Name = input("Enter name: ")
Gender = input("Enter gender: ")
Age = int(input("Enter age: "))

if Age < 18:
    print("Not eligible")
elif Age > 60:
    print("Eligible")
elif Age > 18 and Gender == "F":
    print("{} has right to vote".format(Name))
else:
    if Age > 30 and Gender == "M":
        print("{} has right to vote".format(Name))
    else:
        print("{} has not right to vote".format(Name))
